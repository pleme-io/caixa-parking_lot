   :body "[package]\nname = \"parking_lot-benchmark\"\nversion = \"0.0.0\"\nauthors = [\"Amanieu d'Antras <amanieu@gmail.com>\"]\nedition = \"2021\"\n\n[dependencies]\nparking_lot = {path = \"..\"}\nseqlock = \"0.2\"\nlibc = \"0.2\"\n\n[features]\nnightly = [\"parking_lot/nightly\"]\ndeadlock_detection = [\"parking_lot/deadlock_detection\"]\n\n[target.'cfg(windows)'.dependencies]\nwindows-sys = { version = \"0.60\", features = [\"Win32_System_Threading\"] }\n"} {:path "benchmark/src/bin/rwlock.rs"
   :sha256 "4cfa6219f9ba7375faca5d2a9a20550036b0612281980527a1761c8023084604"
